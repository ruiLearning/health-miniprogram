/* pages/checkin/checkin.wxss */

/* ── Streak Card ── */
.streak-card {
  background: linear-gradient(135deg, #1AAD74 0%, #0D9158 100%);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(26, 173, 116, 0.3);
}
.streak-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.streak-left { }
.streak-num {
  font-size: 88rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
}
.streak-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 4rpx;
}
.streak-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}
.streak-fire { font-size: 64rpx; line-height: 1; }
.streak-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.streak-em {
  color: #fff;
  font-weight: 700;
}

/* Week row */
.week-row {
  display: flex;
  justify-content: space-between;
  background: rgba(0,0,0,0.12);
  border-radius: 20rpx;
  padding: 16rpx 12rpx;
  gap: 4rpx;
}
.week-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.wi-day {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
}
.wi-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}
.wi-check {
  font-size: 20rpx;
  color: #1AAD74;
  font-weight: 700;
}
.week-item.done .wi-dot {
  background: #fff;
}
.week-item.today .wi-dot {
  background: rgba(255,255,255,0.95);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.35);
}
.week-item.future .wi-dot {
  opacity: 0.3;
}
.wi-date {
  font-size: 18rpx;
  color: rgba(255,255,255,0.5);
}
.week-item.done .wi-date,
.week-item.today .wi-date {
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

/* ── Section header ── */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}
.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.done-badge {
  display: flex;
  align-items: baseline;
  background: #ECFDF5;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.done-num {
  font-size: 28rpx;
  font-weight: 800;
  color: #1AAD74;
}
.done-total {
  font-size: 22rpx;
  color: #6EE7B7;
}

/* ── Task Grid: 3 per row ── */
.task-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.task-card {
  border-radius: 24rpx;
  padding: 22rpx 16rpx 20rpx;
  border: 2rpx solid transparent;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
.task-card:active { opacity: 0.72; transform: scale(0.95); }

.task-row-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}
.task-icon-wrap {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.task-icon {
  font-size: 40rpx;
  line-height: 1;
}
.task-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #DDD;
  background: rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.task-check.checked {
  background: #1AAD74;
  border-color: #1AAD74;
}
.check-mark {
  font-size: 18rpx;
  color: #fff;
  font-weight: 800;
}
.task-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.3;
}

/* ── Shared card title ── */
.card-title-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
}

/* ── Water Card ── */
.water-card { margin-bottom: 20rpx; }
.water-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.water-title-wrap { }
.water-sub {
  font-size: 22rpx;
  color: #AAA;
  margin-top: 4rpx;
  display: block;
}
.water-stat { display: flex; align-items: baseline; }
.water-count {
  font-size: 52rpx;
  font-weight: 900;
  color: #3B82F6;
  line-height: 1;
}
.water-total { font-size: 26rpx; color: #AAA; }

.water-bar-wrap {
  height: 8rpx;
  background: #EFF6FF;
  border-radius: 4rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}
.water-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #93C5FD, #3B82F6);
  border-radius: 4rpx;
  transition: width 0.4s ease;
  min-width: 0;
  max-width: 100%;
}

.water-cups {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 24rpx;
}
.water-cup {
  width: 68rpx;
  height: 76rpx;
  border-radius: 8rpx 8rpx 18rpx 18rpx;
  border: 2rpx solid #BFDBFE;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.water-cup.filled {
  background: #EFF6FF;
  border-color: #3B82F6;
}
.water-cup:active { transform: scale(0.88); }
.cup-icon { font-size: 28rpx; color: #BFDBFE; }
.water-cup.filled .cup-icon { color: #3B82F6; }

.water-btns { display: flex; gap: 16rpx; }
.water-btn {
  flex: 1;
  padding: 18rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}
.water-btn.minus { background: #F5F5F5; color: #888; }
.water-btn.plus  { background: #EFF6FF; color: #3B82F6; }
.water-btn:active { opacity: 0.75; }

/* ── Mood Card ── */
.mood-card { margin-bottom: 20rpx; }
.mood-row {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}
.mood-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 8rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  background: #F8F8F8;
  transition: all 0.2s;
}
.mood-item.active {
  background: #FFF8E7;
  border-color: #F08C00;
}
.mood-item:active { transform: scale(0.93); }
.mood-emoji { font-size: 44rpx; }
.mood-label { font-size: 20rpx; color: #999; }
.mood-item.active .mood-label { color: #F08C00; font-weight: 600; }

/* ── Weight Card ── */
.weight-card { margin-bottom: 20rpx; }
.weight-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.weight-date-picker {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #EDF3F8;
  font-size: 22rpx;
  color: #536173;
}
.weight-date-sub {
  margin-top: -10rpx;
  margin-bottom: 18rpx;
  font-size: 22rpx;
  color: #9AA3AF;
}
.weight-history-scroll {
  white-space: nowrap;
  margin-bottom: 18rpx;
}
.weight-history-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  margin-right: 14rpx;
  border-radius: 22rpx;
  background: #F6F8FB;
  color: #8A94A6;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.weight-history-chip.has-data {
  background: #EDF8F2;
  color: #4C7A64;
}
.weight-history-chip.active {
  background: linear-gradient(135deg, #1AAD74, #159764);
  color: #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(26, 173, 116, 0.22);
}
.weight-history-week {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}
.weight-history-day {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
}
.weight-input-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F8F8F8;
  border-radius: 18rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
}
.weight-input {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.weight-unit { font-size: 26rpx; color: #999; }
.weight-save-btn {
  background: #1AAD74;
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 600;
}
.weight-save-btn:active { opacity: 0.8; }
.weight-diff { font-size: 24rpx; color: #999; }
.diff-up   { color: #EF4444; font-weight: 600; }
.diff-down { color: #1AAD74; font-weight: 600; }

/* ── Shared ── */
.green { color: #1AAD74; }
.bold  { font-weight: 700; }
.blue  { color: #3B82F6; }
.red   { color: #EF4444; }
