/* pages/stats/stats.wxss */

.page-wrap {
  padding-top: 28rpx;
  background:
    radial-gradient(circle at top left, rgba(80, 200, 120, 0.16), transparent 34%),
    linear-gradient(180deg, #f5fbf8 0%, #f3f6fb 32%, #eef2f7 100%);
}

.hero-card {
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.14), transparent 28%),
    linear-gradient(145deg, #163c2f 0%, #245846 58%, #2f6c58 100%);
  box-shadow: 0 18rpx 40rpx rgba(28, 69, 55, 0.22);
}

.hero-kicker {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: rgba(230, 255, 243, 0.72);
}

.hero-title {
  margin-top: 8rpx;
  font-size: 52rpx;
  line-height: 1.08;
  font-weight: 700;
  color: #ffffff;
}

.hero-subtitle {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(234, 246, 240, 0.82);
}

.hero-metrics {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-metric {
  flex: 1;
  min-width: 170rpx;
  padding: 22rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.1);
}

.hero-metric-value {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.hero-metric-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(231, 244, 238, 0.76);
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx 18rpx;
  border-radius: 26rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 10rpx 26rpx rgba(36, 53, 71, 0.08);
}

.green-card { background: linear-gradient(180deg, #f3fcf6 0%, #e0f6e8 100%); }
.blue-card  { background: linear-gradient(180deg, #f2f8ff 0%, #deebff 100%); }
.amber-card { background: linear-gradient(180deg, #fff9ed 0%, #ffefcb 100%); }

.stat-icon {
  font-size: 38rpx;
  margin-bottom: 10rpx;
}

.stat-num {
  font-size: 42rpx;
  line-height: 1;
  font-weight: 800;
  color: #18212f;
}

.stat-lbl {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: #667085;
}

.card {
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  box-shadow: 0 14rpx 34rpx rgba(37, 55, 77, 0.08);
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  margin-bottom: 6rpx;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: none;
  color: #152033;
}

.section-desc {
  font-size: 22rpx;
  line-height: 1.6;
  color: #7d8898;
}

.section-chip {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf3f0;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 700;
  color: #4f6b5d;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f6f8fb;
  font-size: 22rpx;
  color: #64748b;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.green-dot { background: #1aad74; }
.amber-dot { background: #f08c00; }
.red-dot { background: #ef4444; }

.chart-canvas {
  width: 100%;
  height: 320rpx;
  display: block;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fbfcfe 0%, #f4f7fb 100%);
}

.chart-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 12rpx;
  margin-top: 12rpx;
}

.chart-lbl {
  flex: 1;
  text-align: center;
  font-size: 20rpx;
  color: #94a3b8;
}

.macro-dist {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 4rpx 0 0;
}

.nutrition-card {
  background: linear-gradient(180deg, #fffdf9 0%, #ffffff 42%);
}

.nutrition-chip {
  background: #f6efe5;
  color: #8e6d4f;
}

.dist-ring-wrap {
  flex-shrink: 0;
  padding: 12rpx;
  border-radius: 24rpx;
  background: radial-gradient(circle at top, #ffffff 0%, #fbf5ee 100%);
  box-shadow: inset 0 0 0 1rpx rgba(224, 211, 194, 0.5);
}

.dist-canvas {
  width: 152px;
  height: 152px;
}

.dist-legend {
  flex: 1;
  min-width: 260rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dist-item {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  padding: 12rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.74);
  box-shadow: inset 0 0 0 1rpx rgba(236, 229, 219, 0.9);
}

.dist-accent {
  width: 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.dist-info {
  flex: 1;
}

.dist-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.dist-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #3d4756;
}

.dist-pct {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  line-height: 1;
  font-weight: 700;
}

.dist-val {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #162033;
}

.dist-kcal {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #9aa4b1;
}

.dist-empty {
  color: #b4bcc8;
  font-weight: 400;
}

.dist-empty-tip {
  padding: 2rpx 6rpx 0;
  font-size: 20rpx;
  line-height: 1.6;
  color: #a0aab7;
}

.weight-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.weight-period {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef6f2;
  font-size: 20rpx;
  font-weight: 700;
  color: #4d6c5d;
}

.weight-summary {
  display: flex;
  align-items: center;
  background: linear-gradient(180deg, #f8fbfa 0%, #f2f7f5 100%);
  border-radius: 22rpx;
  padding: 18rpx 0;
  margin-bottom: 24rpx;
}

.wsummary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.wsummary-val {
  font-size: 32rpx;
  line-height: 1;
  font-weight: 800;
  color: #162033;
}

.wsummary-lbl {
  font-size: 20rpx;
  color: #8a96a8;
}

.wsummary-divider {
  width: 1rpx;
  height: 52rpx;
  background: rgba(122, 142, 162, 0.18);
}

.weight-canvas {
  width: 100%;
  height: 300rpx;
  display: block;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fbfefd 0%, #f4faf7 100%);
}

.green { color: #1aad74; }
.red { color: #ef4444; }
.bold { font-weight: 700; }

.task-rate-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rate-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.rate-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 1rpx rgba(148, 163, 184, 0.16);
  flex-shrink: 0;
}

.rate-info {
  flex: 1;
}

.rate-name {
  margin-bottom: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #172033;
}

.rate-bar-wrap {
  height: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e9eef5;
}

.rate-bar {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.6s ease;
}

.rate-pct {
  width: 78rpx;
  text-align: right;
  font-size: 25rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.bmi-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 28rpx;
}

.bmi-num-wrap {
  min-width: 170rpx;
  padding: 26rpx 22rpx;
  border-radius: 24rpx;
  text-align: center;
  background: linear-gradient(180deg, #f5f8fc 0%, #edf3f9 100%);
}

.bmi-num {
  font-size: 56rpx;
  line-height: 1;
  font-weight: 800;
  color: #172033;
}

.bmi-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8c98aa;
}

.bmi-detail {
  flex: 1;
}

.bmi-status {
  margin-bottom: 6rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.bmi-range {
  margin-bottom: 16rpx;
  font-size: 22rpx;
  color: #8894a8;
}

.bmi-bar-track {
  position: relative;
  height: 12rpx;
  margin-bottom: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #93c5fd 0%, #1aad74 40%, #f08c00 70%, #ef4444 100%);
}

.bmi-bar-fill {
  position: absolute;
  top: -6rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.16);
  transform: translateX(-50%);
}

.bmi-ticks {
  display: flex;
  justify-content: space-between;
  font-size: 18rpx;
  color: #95a0b2;
}
