/* pages/masters/detail/detail.wxss */

.detail-wrap {
  height: 100vh;
  background: #F4F6FA;
}

/* Header */
.detail-header {
  background: #FFFFFF;
  padding: 32rpx 32rpx 24rpx;
  margin-bottom: 16rpx;
}
.detail-source {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}
.platform-tag {
  background: #FFF0F5;
  color: #FF2C55;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.detail-author {
  font-size: 26rpx;
  color: #555;
  font-weight: 600;
  flex: 1;
}
.detail-date {
  font-size: 22rpx;
  color: #BBB;
}
.detail-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.6;
  margin-bottom: 20rpx;
}
.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.tag-item {
  font-size: 22rpx;
  color: #1AAD74;
  background: #ECFDF5;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* Cards */
.detail-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 20rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

/* Section */
.sec-heading {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}
.sec-num {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #1AAD74, #0E9058);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.sec-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.sec-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

/* Table */
.table-scroll {
  width: 100%;
  margin-bottom: 24rpx;
}
.table-wrap {
  min-width: 100%;
  width: max-content;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #F0F0F0;
}
.table-row {
  display: flex;
}
.table-head-row {
  background: linear-gradient(135deg, #1AAD74, #0E9058);
}
.row-even { background: #FFFFFF; }
.row-odd  { background: #F9FBFA; }
.table-cell {
  flex: 1;
  min-width: 110rpx;
  padding: 16rpx 12rpx;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
  border-right: 1rpx solid #F0F0F0;
}
.table-cell:last-child {
  border-right: none;
}
.table-head {
  color: #FFFFFF;
  font-weight: 600;
  font-size: 22rpx;
  border-right-color: rgba(255,255,255,0.2);
}

/* Note */
.sec-note {
  display: flex;
  gap: 12rpx;
  background: #FFFBEB;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 8rpx;
}
.note-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.note-text {
  font-size: 24rpx;
  color: #7A5C00;
  line-height: 1.7;
}

/* Tips */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 8rpx;
}
.tip-item {
  display: flex;
  gap: 14rpx;
  align-items: flex-start;
}
.tip-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #1AAD74;
  flex-shrink: 0;
  margin-top: 12rpx;
}
.tip-text {
  font-size: 26rpx;
  color: #444;
  line-height: 1.7;
  flex: 1;
}

/* Conclusion */
.conclusion-card {
  background: linear-gradient(160deg, #ECFDF5, #D1FAE5);
  margin-bottom: 48rpx;
}
.conclusion-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #0E9058;
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}
.conclusion-text {
  font-size: 28rpx;
  color: #1A5C3A;
  line-height: 1.8;
}
